+  FDKaacEnc_reduceThresholdsCBR(
+      qcChannels, psyChannels, ahFlag, thrExp, 1,
+      (FIXP_DBL)reduction_mantissa_q31, (SCHAR)reduction_exponent);
+
+  for (int sfb = 0; sfb < sfb_count; ++sfb) {
