+  if (current == NULL || previous == NULL || frequency_bits == NULL ||
+      time_bits == NULL || bands <= 0 || bands > MAX_FREQ_COEFFS ||
+      channel < 0 || channel > 1) {
+    return -1;
+  }
+  SBR_ENV_DATA envData = {};
+  SBR_CODE_ENVELOPE envelope = {};
+  SBR_CODE_ENVELOPE noise = {};
