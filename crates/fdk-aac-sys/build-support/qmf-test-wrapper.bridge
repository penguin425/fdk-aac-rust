extern "C" int fdk_fft32_test(const LONG *input, LONG *output, int *scale) {
  if (input == nullptr || output == nullptr || scale == nullptr) return -1;
  std::memcpy(output, input, 64 * sizeof(LONG));
  int local_scale = 0;
  fft(32, output, &local_scale);
  *scale = local_scale;
  return 0;
}

extern "C" int fdk_qmf_analysis32_test(const LONG *input, int samples,
                                        LONG *real_out, LONG *imag_out,
                                        int *lb_scale) {
  if (samples <= 0 || (samples % 32) != 0) return -1;
  const int slots = samples / 32;
  QMF_FILTER_BANK bank;
  FIXP_DBL states[10 * 32];
  FIXP_DBL work[2 * 32];
  std::memset(states, 0, sizeof(states));
  if (qmfInitAnalysisFilterBank(&bank, states, slots, 32, 32, 32, 0) != 0)
    return -2;
  FIXP_DBL *real[32];
  FIXP_DBL *imag[32];
  if (slots > 32) return -3;
  for (int slot = 0; slot < slots; ++slot) {
    real[slot] = real_out + slot * 32;
    imag[slot] = imag_out + slot * 32;
  }
  QMF_SCALE_FACTOR scale;
  qmfAnalysisFiltering(&bank, real, imag, &scale, input, 0, 1, work);
  if (lb_scale != nullptr) *lb_scale = scale.lb_scale;
  return 0;
}

extern "C" int fdk_qmf_analysis_usac_test(const LONG *input, int samples,
                                           int channels, LONG *real_out,
                                           LONG *imag_out, int *lb_scale) {
  if (input == nullptr || real_out == nullptr || imag_out == nullptr ||
      (channels != 16 && channels != 24) || samples <= 0 ||
      (samples % channels) != 0)
    return -1;
  const int slots = samples / channels;
  if (slots > 32) return -3;
  QMF_FILTER_BANK bank;
  std::vector<FIXP_DBL> states(static_cast<size_t>(10 * channels));
  std::vector<FIXP_DBL> work(static_cast<size_t>(2 * channels));
  if (qmfInitAnalysisFilterBank(&bank, states.data(), slots, channels, channels,
                                channels, 0) != 0)
    return -2;
  FIXP_DBL *real[32];
  FIXP_DBL *imag[32];
  for (int slot = 0; slot < slots; ++slot) {
    real[slot] = real_out + slot * channels;
    imag[slot] = imag_out + slot * channels;
  }
  QMF_SCALE_FACTOR scale;
  qmfAnalysisFiltering(&bank, real, imag, &scale, input, 0, 1, work.data());
  if (lb_scale != nullptr) *lb_scale = scale.lb_scale;
  return 0;
}

