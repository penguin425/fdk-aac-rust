  FIXP_DBL states[9 * 64] = {};
  FIXP_DBL work[2 * 64];
  if (qmfInitSynthesisFilterBank(&bank, states, slots, 32, 64, 64,
                                 QMF_FLAG_CLDFB) != 0)
    return -2;
  for (int slot = 0; slot < slots; ++slot) {
    qmfSynthesisFilteringSlot(&bank, real_in + slot * 64,
                              imag_in + slot * 64, 0, 0,
                              output + slot * 64, 1, work);
  }
  return 0;
}

extern "C" int fdk_qmf_roundtrip32_64_test(const LONG *input, int samples,
                                            LONG *output) {
  if (samples <= 0 || samples % 32 != 0 || samples / 32 > 32) return -1;
  const int slots = samples / 32;
  QMF_FILTER_BANK analysis;
  QMF_FILTER_BANK synthesis;
  FIXP_DBL analysis_states[10 * 32] = {};
  FIXP_DBL synthesis_states[9 * 64] = {};
  FIXP_DBL analysis_work[2 * 32];
  FIXP_DBL synthesis_work[2 * 64];
  FIXP_DBL real_data[32][64] = {};
  FIXP_DBL imag_data[32][64] = {};
  FIXP_DBL *real[32];
  FIXP_DBL *imag[32];
  for (int slot = 0; slot < slots; ++slot) {
    real[slot] = real_data[slot];
    imag[slot] = imag_data[slot];
  }
  if (qmfInitAnalysisFilterBank(&analysis, analysis_states, slots, 32, 32, 32,
                                0) != 0)
    return -2;
  if (qmfInitSynthesisFilterBank(&synthesis, synthesis_states, slots, 32, 32,
                                 64, 0) != 0)
    return -3;
  QMF_SCALE_FACTOR scale;
  qmfAnalysisFiltering(&analysis, real, imag, &scale, input, 0, 1,
                       analysis_work);
  for (int slot = 0; slot < slots; ++slot) {
    qmfSynthesisFilteringSlot(&synthesis, real[slot], imag[slot],
                              scale.lb_scale, scale.lb_scale,
                              output + slot * 64, 1, synthesis_work);
  }
  return 0;
}

extern "C" int fdk_qmf_roundtrip32_cldfb_test(const LONG *input, int samples,
                                                LONG *output) {
  if (samples <= 0 || samples % 32 != 0 || samples / 32 > 32) return -1;
  const int slots = samples / 32;
  QMF_FILTER_BANK analysis;
  QMF_FILTER_BANK synthesis;
  FIXP_DBL analysis_states[10 * 32] = {};
  FIXP_DBL synthesis_states[9 * 32] = {};
  FIXP_DBL analysis_work[2 * 32];
  FIXP_DBL synthesis_work[2 * 32];
  FIXP_DBL real_data[32][64] = {};
  FIXP_DBL imag_data[32][64] = {};
  FIXP_DBL *real[32];
  FIXP_DBL *imag[32];
  for (int slot = 0; slot < slots; ++slot) {
    real[slot] = real_data[slot];
    imag[slot] = imag_data[slot];
  }
  if (qmfInitAnalysisFilterBank(&analysis, analysis_states, slots, 32, 32, 32,
                                QMF_FLAG_CLDFB) != 0)
    return -2;
  if (qmfInitSynthesisFilterBank(&synthesis, synthesis_states, slots, 32, 32,
                                 32, QMF_FLAG_CLDFB) != 0)
    return -3;
  QMF_SCALE_FACTOR scale;
  qmfAnalysisFiltering(&analysis, real, imag, &scale, input, 0, 1,
                       analysis_work);
  qmfChangeOutScalefactor(&synthesis, -8);
  qmfSynthesisFiltering(&synthesis, real, imag, &scale, 0, output, 1,
                        synthesis_work);
  return 0;
}
