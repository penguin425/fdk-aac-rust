extern "C" int fdk_qmf_synthesis64_test(const LONG *real_in,
                                         const LONG *imag_in, int slots,
                                         LONG *output) {
  if (slots <= 0 || slots > 32) return -1;
  QMF_FILTER_BANK bank;
  FIXP_DBL states[9 * 64];
  FIXP_DBL work[2 * 64];
  std::memset(states, 0, sizeof(states));
  if (qmfInitSynthesisFilterBank(&bank, states, slots, 32, 64, 64, 0) != 0)
    return -2;
  for (int slot = 0; slot < slots; ++slot) {
    qmfSynthesisFilteringSlot(&bank, real_in + slot * 64,
                              imag_in + slot * 64, 0, 0,
                              output + slot * 64, 1, work);
  }
  return 0;
}

